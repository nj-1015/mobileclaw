{
  "name": "mobileclaw",
  "version": "1.2.26",
  "description": "Secure AI agents on Android. Four-layer protection with proot sandbox, operator approval, and cost tracking.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mobileclaw": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build-agent-runner.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@onecli-sh/sdk": "^0.2.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "cron-parser": "^5.5.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^146.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.0",
    "sql.js": "^1.14.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
