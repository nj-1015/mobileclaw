# MobileClaw configuration
# Copy to .env and edit as needed

# Assistant identity
MOBILECLAW_ASSISTANT_NAME="Andy"
MOBILECLAW_HAS_OWN_NUMBER=false

# Web UI port (default: 3002)
# MOBILECLAW_WEB_PORT=3002

# Logging level: trace | debug | info | warn | error | fatal
# MOBILECLAW_LOG_LEVEL=info

# Sandbox settings
# MOBILECLAW_IDLE_TIMEOUT=1800000
# MOBILECLAW_MAX_SANDBOXES=5
# MOBILECLAW_SANDBOX_TIMEOUT=1800000

# Channel tokens (set by channel skills)
# TELEGRAM_BOT_TOKEN=
